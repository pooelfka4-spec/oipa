local player = game.Players.LocalPlayer

--// KEY
local correctKey = "Nattapong"
local unlocked = false

--// GUI หลัก
local gui = Instance.new("ScreenGui")
gui.Name = "MusicGui"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

--// KEY FRAME
local keyFrame = Instance.new("Frame", gui)
keyFrame.Size = UDim2.new(0,200,0,120)
keyFrame.Position = UDim2.new(0.5,-100,0.5,-60)
keyFrame.BackgroundColor3 = Color3.fromRGB(30,30,30)

local keyTitle = Instance.new("TextLabel", keyFrame)
keyTitle.Size = UDim2.new(1,0,0,25)
keyTitle.Text = "Enter Key"
keyTitle.BackgroundTransparency = 1
keyTitle.TextColor3 = Color3.new(1,1,1)

local keyBox = Instance.new("TextBox", keyFrame)
keyBox.Size = UDim2.new(1,-20,0,25)
keyBox.Position = UDim2.new(0,10,0,35)
keyBox.PlaceholderText = "ใส่คีย์..."

local keyBtn = Instance.new("TextButton", keyFrame)
keyBtn.Size = UDim2.new(1,-20,0,25)
keyBtn.Position = UDim2.new(0,10,0,70)
keyBtn.Text = "CONFIRM"

--// MUSIC FRAME (ซ่อนก่อน)
local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0,200,0,110)
frame.Position = UDim2.new(0,20,0.5,-55)
frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
frame.Visible = false
frame.Active = true
frame.Draggable = true

-- ปุ่มเปิด/ปิด GUI
local openBtn = Instance.new("TextButton", gui)
openBtn.Size = UDim2.new(0,60,0,25)
openBtn.Position = UDim2.new(0,20,0.5,60)
openBtn.Text = "OPEN"
openBtn.Visible = false

-- Title
local title = Instance.new("TextLabel", frame)
title.Size = UDim2.new(1,0,0,25)
title.Text = "Music Player"
title.BackgroundTransparency = 1
title.TextColor3 = Color3.new(1,1,1)

-- ช่องใส่ ID เพลง
local textbox = Instance.new("TextBox", frame)
textbox.Size = UDim2.new(1,-20,0,25)
textbox.Position = UDim2.new(0,10,0,35)
textbox.PlaceholderText = "ใส่ ID เพลง..."

-- ปุ่มเล่น
local playBtn = Instance.new("TextButton", frame)
playBtn.Size = UDim2.new(1,-20,0,25)
playBtn.Position = UDim2.new(0,10,0,70)
playBtn.Text = "PLAY"

--// Remote
local RE = game:GetService("ReplicatedStorage"):WaitForChild("RE")

local function playMusic(id)
    pcall(function()
        RE:WaitForChild("PlayerToolEvent"):FireServer("ToolMusicText", id, nil, true)
    end)

    pcall(function()
        RE:WaitForChild("1NoMoto1rVehicle1s"):FireServer("PickingScooterMusicText", id, nil, true)
    end)
end

-- กด PLAY
playBtn.MouseButton1Click:Connect(function()
    if not unlocked then return end
    local id = textbox.Text
    if id ~= "" then
        playMusic(id)
    end
end)

-- เปิด/ปิด GUI
local open = true
openBtn.MouseButton1Click:Connect(function()
    frame.Visible = not frame.Visible
    openBtn.Text = frame.Visible and "CLOSE" or "OPEN"
end)

-- ตรวจ KEY
keyBtn.MouseButton1Click:Connect(function()
    if keyBox.Text == correctKey then
        unlocked = true
        keyFrame.Visible = false
        frame.Visible = true
        openBtn.Visible = true
    else
        keyTitle.Text = "Wrong Key!"
    end
end)
